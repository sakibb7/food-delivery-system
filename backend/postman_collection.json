    {
      "name": "Google OAuth",
      "item": [
        {
          "name": "Google OAuth — Redirect to Google",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "google"
              ]
            },
            "description": "Initiates Google OAuth flow. Redirects the user to Google's consent screen.\n\n**Note:** This sets an `oauth_state` cookie for CSRF protection. Best tested in a browser rather than Postman.\n\n**Open this URL in a browser:** http://localhost:5000/api/v1/auth/google"
          },
          "response": []
        },
        {
          "name": "Google OAuth — Callback (reference only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google/callback?code=AUTHORIZATION_CODE_FROM_GOOGLE&state=STATE_FROM_COOKIE",
              "host": [
                "{{baseUrl}}"
              ],
