                  "    pm.test('Logout successful', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.message).to.eql('Logout successful');",
                  "    });",
                  "    console.log('✅ Logged out. Cookies cleared.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
